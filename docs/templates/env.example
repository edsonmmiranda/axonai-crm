# =============================================================================
# .env.example — Template de variáveis de ambiente
# =============================================================================
#
# COMO USAR:
#   1. Copie este arquivo para `.env.local` na raiz do projeto:
#        cp .env.example .env.local
#   2. Preencha cada variável com os valores reais do seu projeto.
#   3. NUNCA commite `.env.local` — ele já está no `.gitignore`.
#   4. Este arquivo (`.env.example`) é versionado e serve como documentação
#      viva das variáveis que a aplicação espera.
#
# REGRA DURA DO FRAMEWORK:
#   - `.env.local` é read-only para os agentes (inclusive Tech Lead).
#   - Somente VOCÊ (humano) edita `.env.local`.
#   - Se faltar alguma variável, o preflight do Tech Lead aborta o sprint.
#
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — OBRIGATÓRIO
# -----------------------------------------------------------------------------
# Onde encontrar: https://supabase.com/dashboard → [seu projeto] → Project Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL
#   URL pública do seu projeto Supabase. Formato: https://<project-ref>.supabase.co
#   Usado pelo cliente (browser) e pelo servidor. Pode ser exposto publicamente.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# NEXT_PUBLIC_SUPABASE_ANON_KEY
#   Chave anônima (JWT longo começando com "eyJ..."). Respeita RLS — segura para
#   expor no browser. É o que o cliente usa para autenticar requests do usuário.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-key...

# SUPABASE_SERVICE_ROLE_KEY
#   Chave de service role (JWT longo começando com "eyJ..."). BYPASSA RLS.
#   NUNCA exponha no browser. Usada só em Server Actions / scripts admin /
#   migrations. Se vazar, o banco inteiro fica exposto — rotacione imediatamente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...your-service-role-key...


# -----------------------------------------------------------------------------
# App — OPCIONAL (recomendado a partir de produção)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL
#   URL canônica da aplicação. Usada em emails de auth do Supabase, metadados
#   OpenGraph, redirects, callbacks de webhook. Em dev, http://localhost:3000.
#   Em produção, a URL pública final (ex.: https://app.exemplo.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Integrações de API externa — preencher conforme forem adicionadas
# -----------------------------------------------------------------------------
# Cada integração nova criada por @api-integrator adiciona suas variáveis aqui.
# Convenção de nomes:
#   [API_NAME]_API_KEY              — chave principal
#   [API_NAME]_WEBHOOK_SECRET       — secret para validar assinatura de webhook
#   [API_NAME]_BASE_URL             — se a URL variar por ambiente
#
# Exemplo:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...


# -----------------------------------------------------------------------------
# NOTAS SOBRE GIT
# -----------------------------------------------------------------------------
# Git NÃO usa variáveis de ambiente do projeto. Configuração fica em:
#   - ~/.gitconfig           → user.name, user.email (identidade)
#   - Git credential helper  → credenciais do GitHub/GitLab (gerenciado pelo SO)
# Não há nada a preencher aqui para Git.

# =============================================================================
# .env.example — Template de variáveis de ambiente
# =============================================================================
#
# COMO USAR:
#   1. Copie este arquivo para `.env.local` na raiz do projeto:
#        cp .env.example .env.local
#   2. Preencha cada variável com os valores reais do seu projeto.
#   3. NUNCA commite `.env.local` — ele já está no `.gitignore`.
#   4. Este arquivo (`.env.example`) é versionado e serve como documentação
#      viva das variáveis que a aplicação espera.
#
# REGRA DURA DO FRAMEWORK:
#   - `.env.local` é read-only para os agentes (inclusive Tech Lead).
#   - Somente VOCÊ (humano) edita `.env.local`.
#   - Se faltar alguma variável, o preflight do Tech Lead aborta o sprint.
#
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — OBRIGATÓRIO
# -----------------------------------------------------------------------------
# Onde encontrar: https://supabase.com/dashboard → [seu projeto] → Project Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL
#   URL pública do seu projeto Supabase. Formato: https://<project-ref>.supabase.co
#   Usado pelo cliente (browser) e pelo servidor. Pode ser exposto publicamente.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# NEXT_PUBLIC_SUPABASE_ANON_KEY
#   Chave anônima (JWT longo começando com "eyJ..."). Respeita RLS — segura para
#   expor no browser. É o que o cliente usa para autenticar requests do usuário.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-key...

# SUPABASE_SERVICE_ROLE_KEY
#   Chave de service role (JWT longo começando com "eyJ..."). BYPASSA RLS.
#   NUNCA exponha no browser. Usada só em Server Actions / scripts admin /
#   migrations. Se vazar, o banco inteiro fica exposto — rotacione imediatamente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...your-service-role-key...


# -----------------------------------------------------------------------------
# App — OPCIONAL (recomendado a partir de produção)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL
#   URL canônica da aplicação. Usada em emails de auth do Supabase, metadados
#   OpenGraph, redirects, callbacks de webhook. Em dev, http://localhost:3000.
#   Em produção, a URL pública final (ex.: https://app.exemplo.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Origin isolation — admin × customer (Sprint admin_13 — RNF-SEC-1, RNF-SEC-2)
# -----------------------------------------------------------------------------
# Hostnames distintos para isolar a área admin do customer app:
#   - Customer host: serve /dashboard/*, /login, etc. RECUSA /admin/* (404).
#   - Admin host:    serve /admin/*. RECUSA qualquer outra rota (404).
#
# Em dev (host inclui localhost ou 127.0.0.1) o middleware roda em modo
# permissivo independente destas variáveis, com warning no console.
#
# Em produção, AMBAS as variáveis são obrigatórias — middleware faz hard-fail
# 503 em qualquer /admin/* se ausentes (defesa contra deploy mal-configurado).
#
# Cookies de sessão emitidos com domain=<host atual> + SameSite=Strict
# garantem que sessão admin não vaze para o customer host e vice-versa.
#
# Configuração no Vercel: ambos os hostnames apontam para o mesmo deployment.
# Ver docs/admin_area/runbook_origin_isolation.md.

NEXT_PUBLIC_ADMIN_HOST=admin.example.com
NEXT_PUBLIC_CUSTOMER_HOST=app.example.com


# -----------------------------------------------------------------------------
# Bootstrap email (fallback) — OPCIONAL
# -----------------------------------------------------------------------------
# Sistema de email transacional admin tem fallback chain de 3 níveis
# (Sprint admin_10 — RF-SET-7):
#   1. Credencial cifrada cadastrada via UI em /admin/settings/integrations/email
#   2. Estas variáveis BOOTSTRAP_EMAIL_*   ← este bloco
#   3. Link copiável offline (signup_link_offline_fallback_enabled)
#
# Quando preencher este bloco:
#   - Em incidente onde Vault perde acesso (DB ou extensão indisponível).
#   - Em ambiente novo onde ainda não há credencial cadastrada via UI e o admin
#     prefere setar via env vars em vez de usar offline fallback.
#   - Critério de "configurado": HOST + USER + PASSWORD presentes (port 587,
#     fromEmail = USER, secure = false são defaults se ausentes).
#
# Uso normal (produção estável): deixar este bloco vazio e configurar SMTP
# via UI — credencial fica cifrada em vault.secrets.

BOOTSTRAP_EMAIL_HOST=
BOOTSTRAP_EMAIL_PORT=587
BOOTSTRAP_EMAIL_USER=
BOOTSTRAP_EMAIL_PASSWORD=
BOOTSTRAP_EMAIL_FROM=
BOOTSTRAP_EMAIL_SECURE=false


# -----------------------------------------------------------------------------
# BREAK-GLASS — recuperação de owner via CLI (Sprint admin_12)
# -----------------------------------------------------------------------------
# Definir APENAS em máquinas com autoridade de break-glass (não em laptops dev
# comuns). Cofre SEPARADO da SUPABASE_SERVICE_ROLE_KEY: comprometimento de um
# não deve dar poder de recuperação de owner sem o outro (T-20 / G-21).
#
# Pré-requisito de uso: hash do BREAK_GLASS_SECRET seedado em platform_settings
# (key='break_glass_secret_hash'). Ver docs/admin_area/runbook_break_glass.md.
#
# Rotação sugerida: trimestral, em cadência distinta da service role.

BREAK_GLASS_SECRET=
BREAK_GLASS_OPERATOR=


# -----------------------------------------------------------------------------
# Integrações de API externa — preencher conforme forem adicionadas
# -----------------------------------------------------------------------------
# Cada integração nova criada por @api-integrator adiciona suas variáveis aqui.
# Convenção de nomes:
#   [API_NAME]_API_KEY              — chave principal
#   [API_NAME]_WEBHOOK_SECRET       — secret para validar assinatura de webhook
#   [API_NAME]_BASE_URL             — se a URL variar por ambiente
#
# Exemplo:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...


# -----------------------------------------------------------------------------
# NOTAS SOBRE GIT
# -----------------------------------------------------------------------------
# Git NÃO usa variáveis de ambiente do projeto. Configuração fica em:
#   - ~/.gitconfig           → user.name, user.email (identidade)
#   - Git credential helper  → credenciais do GitHub/GitLab (gerenciado pelo SO)
# Não há nada a preencher aqui para Git.
